# MongoDB connection string (Atlas or local)
DB_CONNECT=mongodb+srv://<user>:<password>@cluster.mongodb.net/tinycrm?retryWrites=true&w=majority

# SMTP credentials for sending emails
EMAIL_ID=you@example.com
EMAIL_PWD=your-app-password

# Secrets — generate with: openssl rand -hex 32
TOKEN_SECRET=change-me-to-a-random-secret
CRYPTR_SECRET=change-me-to-a-random-secret

# Public URL of the frontend (used in email verification links)
FRONTEND_LINK=http://localhost/

# Port the Go server listens on (default 4050)
# PORT=4050
